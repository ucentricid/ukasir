generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model ContentBlock {
  id        String   @id @default(cuid())
  sectionId String   @unique // e.g., 'hero', 'painpoints', 'features'
  data      Json     // Stores the content configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique // e.g., 'home'
  title     String
  blocks    Json     // Array of blocks: [{ id, type, data }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
